<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>策略自迭代管理器 - V5</title>
  <style>
    :root {
      --bg-primary: #0f0f0f;
      --bg-secondary: #1a1a1a;
      --text-primary: #ffffff;
      --text-secondary: #a0a0a0;
      --accent: #667eea;
      --success: #10b981;
      --warning: #f59e0b;
      --danger: #ef4444;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      padding: 40px 20px;
    }
    .container { max-width: 1400px; margin: 0 auto; }
    .header {
      text-align: center;
      margin-bottom: 40px;
    }
    .header h1 { font-size: 32px; margin-bottom: 8px; }
    .header p { color: var(--text-secondary); }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
      gap: 24px;
      margin-bottom: 24px;
    }
    .card {
      background: var(--bg-secondary);
      border-radius: 12px;
      padding: 24px;
    }
    .card-title {
      font-size: 18px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .status-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }
    .status-idle { background: var(--text-secondary); color: var(--bg-primary); }
    .status-running { background: var(--accent); color: white; animation: pulse 2s infinite; }
    .status-success { background: var(--success); color: white; }
    .status-error { background: var(--danger); color: white; }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.7; }
    }
    .progress-bar {
      width: 100%;
      height: 8px;
      background: var(--bg-primary);
      border-radius: 4px;
      overflow: hidden;
      margin: 16px 0;
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--success));
      width: 0%;
      transition: width 0.5s ease;
    }
    .iteration-log {
      font-family: 'SF Mono', Monaco, monospace;
      font-size: 12px;
      color: var(--text-secondary);
      background: var(--bg-primary);
      padding: 16px;
      border-radius: 8px;
      max-height: 200px;
      overflow-y: auto;
      line-height: 1.6;
    }
    .log-entry { margin-bottom: 4px; }
    .log-entry.success { color: var(--success); }
    .log-entry.error { color: var(--danger); }
    .log-entry.info { color: var(--accent); }
    .button {
      background: linear-gradient(135deg, var(--accent), #764ba2);
      color: white;
      border: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      margin-right: 12px;
      transition: opacity 0.2s;
    }
    .button:hover { opacity: 0.9; }
    .button:disabled { opacity: 0.5; cursor: not-allowed; }
    .button-secondary {
      background: var(--bg-primary);
      border: 1px solid var(--text-secondary);
    }
    .strategy-item {
      padding: 16px;
      background: var(--bg-primary);
      border-radius: 8px;
      margin-bottom: 12px;
    }
    .strategy-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }
    .strategy-name { font-weight: 600; }
    .strategy-stats { display: flex; gap: 16px; font-size: 13px; color: var(--text-secondary); }
    .metric { display: flex; flex-direction: column; gap: 4px; }
    .metric-label { font-size: 11px; color: var(--text-secondary); }
    .metric-value { font-size: 16px; font-weight: 600; color: var(--text-primary); }
    .version-list { margin-top: 12px; }
    .version-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 12px;
      background: var(--bg-secondary);
      border-radius: 6px;
      margin-bottom: 6px;
      font-size: 13px;
    }
    .version-score {
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 12px;
    }
    .score-high { background: var(--success); color: white; }
    .score-medium { background: var(--warning); color: black; }
    .score-low { background: var(--danger); color: white; }
    .config-section { margin-bottom: 24px; }
    .config-title {
      font-size: 16px;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .slider-row {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 12px;
    }
    .slider-label { min-width: 120px; font-size: 14px; }
    .slider-input { flex: 1; }
    .slider-value { min-width: 50px; text-align: right; font-weight: 600; }
    .input-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
      margin-bottom: 12px;
    }
    .input-item { display: flex; flex-direction: column; gap: 4px; }
    .input-item label { font-size: 12px; color: var(--text-secondary); }
    .input-item input {
      background: var(--bg-primary);
      border: 1px solid var(--text-secondary);
      border-radius: 6px;
      padding: 8px 12px;
      color: var(--text-primary);
      font-size: 14px;
    }
    .alert {
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 16px;
      font-size: 14px;
    }
    .alert-info { background: rgba(102, 126, 234, 0.2); border-left: 4px solid var(--accent); }
    .alert-warning { background: rgba(245, 158, 11, 0.2); border-left: 4px solid var(--warning); }
  </style>
</head>
<body>
  <div class="container">
    <!-- 页面头部 -->
    <div class="header">
      <h1>🚀 策略自迭代管理器</h1>
      <p>V5 自动迭代系统 - 参数优化与版本管理</p>
    </div>

    <!-- 控制区 -->
    <div class="card" style="margin-bottom: 24px;">
      <div class="config-section">
        <div class="config-title">
          <span>📋</span>
          <span>选择策略</span>
        </div>
        <select id="strategySelect" class="form-select" style="width: 100%; padding: 12px; background: var(--bg-primary); border: 1px solid var(--text-secondary); border-radius: 8px; color: var(--text-primary); font-size: 14px;">
          <option value="double_ma">双均线策略</option>
          <option value="rsi">RSI 超买超卖</option>
          <option value="macd">MACD 金叉死叉</option>
          <option value="bollinger">布林带突破</option>
          <option value="seven_factor">四维度七因子策略</option>
        </select>
      </div>

      <div class="config-section">
        <div class="config-title">
          <span>⚙️</span>
          <span>迭代配置</span>
        </div>
        <div class="input-row">
          <div class="input-item">
            <label>最大迭代次数</label>
            <input type="number" id="maxIterations" value="20" min="1" max="100">
          </div>
          <div class="input-item">
            <label>评分阈值</label>
            <input type="number" id="scoreThreshold" value="70" min="0" max="100">
          </div>
          <div class="input-item">
            <label>并发任务数</label>
            <input type="number" id="parallelTasks" value="4" min="1" max="10">
          </div>
        </div>
      </div>

      <div style="display: flex; gap: 12px; margin-top: 20px;">
        <button class="button" id="startBtn" onclick="startIteration()">🚀 开始自迭代</button>
        <button class="button button-secondary" id="stopBtn" onclick="stopIteration()" disabled>⏹️ 停止</button>
        <button class="button button-secondary" onclick="window.location.href='backtest.html'">← 返回回测</button>
      </div>
    </div>

    <!-- 进度和状态 -->
    <div class="grid">
      <!-- 进度卡片 -->
      <div class="card">
        <div class="card-title">
          <span>📊</span>
          <span>迭代进度</span>
          <span class="status-badge status-idle" id="statusBadge">空闲</span>
        </div>
        <div class="progress-bar">
          <div class="progress-fill" id="progressFill"></div>
        </div>
        <div style="display: flex; justify-content: space-between; font-size: 13px; color: var(--text-secondary);">
          <span>已完成：<span id="completedCount">0</span> / <span id="totalCount">20</span></span>
          <span>预计剩余：<span id="timeRemaining">--</span></span>
        </div>
      </div>

      <!-- 当前最佳配置 -->
      <div class="card">
        <div class="card-title">
          <span>🏆</span>
          <span>当前最佳配置</span>
        </div>
        <div id="bestConfig">
          <div class="strategy-item">
            <div class="strategy-header">
              <span class="strategy-name">暂无配置</span>
            </div>
            <div class="strategy-stats">
              <div class="metric">
                <span class="metric-label">综合评分</span>
                <span class="metric-value">--</span>
              </div>
              <div class="metric">
                <span class="metric-label">夏普比率</span>
                <span class="metric-value">--</span>
              </div>
              <div class="metric">
                <span class="metric-label">最大回撤</span>
                <span class="metric-value">--</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 策略版本历史 -->
    <div class="card" style="margin-top: 24px;">
      <div class="card-title">
        <span>📚</span>
        <span>策略版本历史</span>
      </div>
      <div class="version-list" id="versionList">
        <div class="version-item">
          <span>暂无版本记录</span>
        </div>
      </div>
    </div>

    <!-- 迭代日志 -->
    <div class="card" style="margin-top: 24px;">
      <div class="card-title">
        <span>📝</span>
        <span>迭代日志</span>
      </div>
      <div class="iteration-log" id="iterationLog">
        <div class="log-entry info">等待开始迭代...</div>
      </div>
    </div>
  </div>

  <script>
    let isRunning = false;
    let currentTaskId = null;
    let pollInterval = null;
    let radarChart = null;

    // 从 URL 参数获取初始配置
    function getUrlParams() {
      const params = new URLSearchParams(window.location.search);
      return {
        strategyType: params.get('strategyType') || 'double_ma',
        stocks: params.get('stocks') ? params.get('stocks').split(',') : [],
        startDate: params.get('startDate') || '',
        endDate: params.get('endDate') || '',
        config: params.get('config') ? JSON.parse(params.get('config')) : {}
      };
    }

    // 初始化页面
    function initPage() {
      const params = getUrlParams();

      // 设置策略选择
      if (params.strategyType) {
        document.getElementById('strategySelect').value = params.strategyType;
      }

      // 加载版本历史
      loadVersionHistory(params.strategyType || 'double_ma');

      // 如果有传入参数，显示提示
      if (params.stocks.length > 0) {
        addLog(`📥 从回测页导入配置: ${params.stocks.length} 只股票`, 'info');
      }
    }

    // 开始迭代 - 调用真实 API
    async function startIteration() {
      if (isRunning) return;

      const strategyType = document.getElementById('strategySelect').value;
      const maxIterations = parseInt(document.getElementById('maxIterations').value);
      const scoreThreshold = parseInt(document.getElementById('scoreThreshold').value);

      // 获取 URL 参数中的配置
      const urlParams = getUrlParams();
      const stocks = urlParams.stocks.length > 0 ? urlParams.stocks : ['000001.SZ']; // 默认平安银行
      const startDate = urlParams.startDate || '2024-01-01';
      const endDate = urlParams.endDate || '2024-12-31';

      // 更新 UI 状态
      isRunning = true;
      document.getElementById('startBtn').disabled = true;
      document.getElementById('stopBtn').disabled = false;
      document.getElementById('totalCount').textContent = maxIterations;
      updateStatusBadge('running');
      addLog('🚀 启动自迭代任务...', 'info');

      try {
        // 调用真实 API
        const response = await fetch('/api/iteration/start', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            strategyType,
            config: urlParams.config || {},
            maxIterations,
            scoreThreshold,
            stocks,
            startDate,
            endDate
          })
        });

        const result = await response.json();

        if (result.success) {
          currentTaskId = result.taskId;
          addLog(`✅ 任务已创建: ${currentTaskId}`, 'success');

          // 开始轮询状态
          startPolling();
        } else {
          throw new Error(result.error || '启动失败');
        }
      } catch (error) {
        addLog(`❌ 启动失败: ${error.message}`, 'error');
        isRunning = false;
        document.getElementById('startBtn').disabled = false;
        document.getElementById('stopBtn').disabled = true;
        updateStatusBadge('error');
      }
    }

    // 停止迭代
    async function stopIteration() {
      if (!currentTaskId) return;

      try {
        const response = await fetch(`/api/iteration/stop/${currentTaskId}`, {
          method: 'POST'
        });

        const result = await response.json();

        if (result.success) {
          addLog('⏹️ 任务已停止', 'warning');
          stopPolling();
          isRunning = false;
          document.getElementById('startBtn').disabled = false;
          document.getElementById('stopBtn').disabled = true;
          updateStatusBadge('idle');
        }
      } catch (error) {
        addLog(`❌ 停止失败: ${error.message}`, 'error');
      }
    }

    // 开始轮询状态
    function startPolling() {
      if (pollInterval) clearInterval(pollInterval);

      pollInterval = setInterval(async () => {
        if (!currentTaskId) return;

        try {
          const response = await fetch(`/api/iteration/status/${currentTaskId}`);
          const result = await response.json();

          if (result.success) {
            updateTaskStatus(result.task);
          }
        } catch (error) {
          console.error('轮询失败:', error);
        }
      }, 2000); // 每 2 秒轮询一次
    }

    // 停止轮询
    function stopPolling() {
      if (pollInterval) {
        clearInterval(pollInterval);
        pollInterval = null;
      }
    }

    // 更新任务状态
    function updateTaskStatus(task) {
      // 更新进度
      updateProgress(task.currentIteration, task.maxIterations);

      // 更新最佳配置
      if (task.bestParams) {
        updateBestConfig(task.bestScore, task.bestParams);
      }

      // 添加日志
      if (task.history && task.history.length > 0) {
        const latest = task.history[task.history.length - 1];
        if (!latest.logged) {
          addLog(`第 ${latest.iteration} 轮: 得分 ${latest.score?.toFixed(1) || '--'}`, latest.error ? 'error' : 'info');
          latest.logged = true;
        }
      }

      // 检查任务完成
      if (task.status === 'completed') {
        addLog(`✅ 迭代完成！最终得分: ${task.bestScore?.toFixed(1)}`, 'success');
        finishIteration();
        loadVersionHistory(task.strategyType);
      } else if (task.status === 'failed' || task.status === 'stopped') {
        addLog(`⏹️ 任务${task.status === 'failed' ? '失败' : '已停止'}`, task.status === 'failed' ? 'error' : 'warning');
        finishIteration();
      }
    }

    // 完成迭代
    function finishIteration() {
      stopPolling();
      isRunning = false;
      currentTaskId = null;
      document.getElementById('startBtn').disabled = false;
      document.getElementById('stopBtn').disabled = true;
      updateStatusBadge('success');
    }

    // 更新状态徽章
    function updateStatusBadge(status) {
      const badge = document.getElementById('statusBadge');
      badge.className = 'status-badge';

      switch (status) {
        case 'running':
          badge.textContent = '运行中';
          badge.classList.add('status-running');
          break;
        case 'success':
          badge.textContent = '完成';
          badge.classList.add('status-success');
          break;
        case 'error':
          badge.textContent = '错误';
          badge.classList.add('status-error');
          break;
        default:
          badge.textContent = '空闲';
          badge.classList.add('status-idle');
      }
    }

    // 更新进度
    function updateProgress(current, total) {
      const percent = (current / total) * 100;
      document.getElementById('progressFill').style.width = percent + '%';
      document.getElementById('completedCount').textContent = current;
    }

    // 更新最佳配置
    function updateBestConfig(score, params) {
      const container = document.getElementById('bestConfig');
      container.innerHTML = `
        <div class="strategy-item">
          <div class="strategy-header">
            <span class="strategy-name">最佳配置</span>
            <span class="version-score ${score >= 80 ? 'score-high' : score >= 60 ? 'score-medium' : 'score-low'}">${score?.toFixed(1)}</span>
          </div>
          <div class="strategy-stats">
            <div class="metric">
              <span class="metric-label">综合评分</span>
              <span class="metric-value">${score?.toFixed(1) || '--'}</span>
            </div>
          </div>
          <pre style="margin-top: 8px; font-size: 11px; color: var(--text-secondary); white-space: pre-wrap;">${JSON.stringify(params, null, 2)}</pre>
        </div>
      `;

      // 更新雷达图
      if (params.metrics) {
        updateRadarChart(params.metrics);
      }
    }

    // 加载版本历史
    async function loadVersionHistory(strategyType) {
      try {
        const response = await fetch(`/api/iteration/versions/${strategyType}`);
        const result = await response.json();

        if (result.success && result.versions.length > 0) {
          renderVersionList(result.versions);
        } else {
          document.getElementById('versionList').innerHTML = `
            <div class="version-item">
              <span style="color: var(--text-secondary);">暂无版本记录</span>
            </div>
          `;
        }
      } catch (error) {
        console.error('加载版本历史失败:', error);
      }
    }

    // 渲染版本列表
    function renderVersionList(versions) {
      const container = document.getElementById('versionList');
      container.innerHTML = versions.map((v, index) => `
        <div class="version-item" onclick="compareVersions('${v.version_id}')">
          <div>
            <span style="font-weight: 600;">V${versions.length - index}</span>
            <span style="color: var(--text-secondary); margin-left: 8px;">${v.strategy_name || '未命名'}</span>
            <span style="color: var(--text-secondary); margin-left: 8px; font-size: 11px;">${v.created_at?.split('T')[0] || ''}</span>
          </div>
          <span class="version-score ${(v.backtest_score || 0) >= 80 ? 'score-high' : (v.backtest_score || 0) >= 60 ? 'score-medium' : 'score-low'}">
            ${(v.backtest_score || 0).toFixed(1)}
          </span>
        </div>
      `).join('');
    }

    // 对比版本
    let selectedVersions = [];
    function compareVersions(versionId) {
      const index = selectedVersions.indexOf(versionId);
      if (index > -1) {
        selectedVersions.splice(index, 1);
      } else if (selectedVersions.length < 3) {
        selectedVersions.push(versionId);
      }

      if (selectedVersions.length >= 2) {
        doCompare();
      }
    }

    async function doCompare() {
      if (selectedVersions.length < 2) return;

      try {
        const response = await fetch(`/api/iteration/compare?versionIds=${selectedVersions.join(',')}`);
        const result = await response.json();

        if (result.success) {
          addLog(`📊 版本对比完成，最佳版本得分: ${result.comparison.best?.backtest_score?.toFixed(1)}`, 'info');

          // 更新雷达图显示对比
          if (result.comparison.versions.length > 0) {
            updateComparisonRadar(result.comparison.versions);
          }
        }
      } catch (error) {
        addLog(`❌ 版本对比失败: ${error.message}`, 'error');
      }

      selectedVersions = [];
    }

    // 添加日志
    function addLog(message, type = 'info') {
      const log = document.getElementById('iterationLog');
      const entry = document.createElement('div');
      entry.className = `log-entry ${type}`;
      const timestamp = new Date().toLocaleTimeString('zh-CN');
      entry.textContent = `[${timestamp}] ${message}`;
      log.appendChild(entry);
      log.scrollTop = log.scrollHeight;
    }

    // 更新雷达图
    function updateRadarChart(metrics) {
      if (!radarChart) return;

      const data = [
        normalizeScore(metrics.sharpeRatio, 0, 3),
        normalizeScore(100 - (metrics.maxDrawdown || 0) * 100, 0, 100),
        normalizeScore(metrics.calmarRatio, 0, 5),
        normalizeScore(metrics.profitLossRatio, 0, 3),
        normalizeScore(metrics.winRate || 0, 0, 100),
        normalizeScore(metrics.totalReturn || 0, -50, 100),
        normalizeScore(metrics.turnover || 50, 0, 100)
      ];

      radarChart.data.datasets[0].data = data;
      radarChart.update();
    }

    // 更新对比雷达图
    function updateComparisonRadar(versions) {
      if (!radarChart) return;

      const colors = [
        'rgba(102, 126, 234, 0.6)',
        'rgba(16, 185, 129, 0.6)',
        'rgba(245, 158, 11, 0.6)'
      ];

      radarChart.data.datasets = versions.map((v, i) => ({
        label: v.strategy_name || `版本 ${i + 1}`,
        data: [
          normalizeScore(v.sharpe_ratio || 0, 0, 3),
          normalizeScore(100 - (v.max_drawdown || 0) * 100, 0, 100),
          normalizeScore(v.calmar_ratio || 0, 0, 5),
          normalizeScore(v.profit_loss_ratio || 0, 0, 3),
          normalizeScore(v.win_rate || 0, 0, 100),
          normalizeScore(v.total_return || 0, -50, 100),
          50 // 默认换手率
        ],
        backgroundColor: colors[i].replace('0.6', '0.2'),
        borderColor: colors[i],
        pointBackgroundColor: colors[i]
      }));

      radarChart.update();
    }

    // 归一化评分到 0-100
    function normalizeScore(value, min, max) {
      return Math.max(0, Math.min(100, ((value - min) / (max - min)) * 100));
    }

    // 页面加载完成
    document.addEventListener('DOMContentLoaded', () => {
      initPage();
      addLog('✅ 页面加载完成，准备就绪', 'info');
    });

    // 监听策略选择变化
    document.getElementById('strategySelect').addEventListener('change', (e) => {
      loadVersionHistory(e.target.value);
    });
  </script>

  <!-- 评分雷达图面板 -->
  <div class="card" style="margin-top: 24px;">
    <div class="card-title">
      <span>📊</span>
      <span>评分雷达图</span>
      <span style="margin-left: auto; font-size: 12px; color: var(--text-secondary);">7 项核心指标</span>
    </div>
    <div style="display: flex; justify-content: center;">
      <canvas id="scoreRadar" width="450" height="400"></canvas>
    </div>
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 16px; margin-top: 16px; font-size: 12px; color: var(--text-secondary);">
      <span>📊 夏普比率</span>
      <span>📉 最大回撤</span>
      <span>📈 卡玛比率</span>
      <span>💰 盈亏比</span>
      <span>🎯 胜率</span>
      <span>💵 总收益</span>
      <span>🔄 换手率</span>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    // 初始化雷达图 - 7 个指标
    function initRadarChart() {
      const ctx = document.getElementById('scoreRadar').getContext('2d');
      radarChart = new Chart(ctx, {
        type: 'radar',
        data: {
          labels: ['夏普比率', '最大回撤', '卡玛比率', '盈亏比', '胜率', '总收益', '换手率'],
          datasets: [{
            label: '当前配置',
            data: [0, 0, 0, 0, 0, 0, 0],
            backgroundColor: 'rgba(102, 126, 234, 0.2)',
            borderColor: 'rgba(102, 126, 234, 1)',
            pointBackgroundColor: 'rgba(102, 126, 234, 1)',
            pointBorderColor: '#fff',
            pointHoverBackgroundColor: '#fff',
            pointHoverBorderColor: 'rgba(102, 126, 234, 1)'
          }]
        },
        options: {
          responsive: true,
          scales: {
            r: {
              min: 0,
              max: 100,
              ticks: { stepSize: 20, color: 'rgba(255,255,255,0.5)' },
              grid: { color: 'rgba(255,255,255,0.1)' },
              angleLines: { color: 'rgba(255,255,255,0.1)' },
              pointLabels: { color: 'rgba(255,255,255,0.8)', font: { size: 12 } }
            }
          },
          plugins: {
            legend: { labels: { color: 'rgba(255,255,255,0.8)' } }
          }
        }
      });
    }

    // 页面加载初始化雷达图
    window.addEventListener('load', initRadarChart);
  </script>
</body>
</html>
<!-- 评分可视化面板 -->
<div class="card" style="margin-top: 24px;">
  <div class="card-title">📊 评分雷达图</div>
  <canvas id="scoreRadar" width="400" height="400"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// 雷达图配置
const radarConfig = {
  type: 'radar',
  data: {
    labels: ['夏普比率', '最大回撤', '卡玛比率', '盈亏比', '胜率', '总收益'],
    datasets: [{
      label: '当前配置',
      data: [80, 70, 75, 85, 65, 90],
      backgroundColor: 'rgba(102, 126, 234, 0.2)',
      borderColor: 'rgba(102, 126, 234, 1)',
      pointBackgroundColor: 'rgba(102, 126, 234, 1)'
    }]
  },
  options: {
    scales: {
      r: {
        min: 0,
        max: 100,
        ticks: { stepSize: 20 }
      }
    }
  }
};

// 初始化雷达图
window.addEventListener('load', () => {
  const ctx = document.getElementById('scoreRadar').getContext('2d');
  new Chart(ctx, radarConfig);
});
</script>
