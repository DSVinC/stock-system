{
  "name": "stock-system",
  "version": "1.0.0",
  "description": "Stock analysis and monitoring system",
  "main": "server.js",
  "scripts": {
    "start": "node api/server.js",
    "test": "node tests/run-all-tests.js",
    "test:unit": "node tests/run-all-tests.js --unit",
    "test:integration": "node tests/run-all-tests.js --integration",
    "test:perf": "node tests/run-all-tests.js --perf",
    "test:acceptance": "node tests/run-all-tests.js --acceptance",
    "test:decision": "node tests/test-decision-engine.js",
    "test:backtest": "node tests/test-backtest-integration.js",
    "test:flow": "node tests/test-full-flow.js",
    "test:performance": "node tests/test-performance.js",
    "test:accept": "node tests/test-acceptance.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "snapshot:update-daily": "bun scripts/update_factor_snapshot_daily.ts",
    "mock:performance": "node scripts/calculate_mock_performance.mjs",
    "update:industry": "node scripts/update_valuation_data.mjs --type=industry",
    "update:pe": "node scripts/update_valuation_data.mjs --type=pe",
    "update:atr": "node scripts/update_valuation_data.mjs --type=atr"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "playwright": "^1.58.2"
  }
}
