    "position": {
      "core_ratio": 0.60,
      "satellite_ratio": 0.40,
      "satellite_count": 4
    },
    "grid": {
      "step": 0.015,
      "price_range": "6_months",
      "single_amount": 40000,
      "trend_filter": true
    },
    "risk_control": {
      "max_drawdown": -0.25,
      "min_annual_return": 0.12,
      "min_win_rate": 0.60
    }
  },
  "compatible_with": ["selection", "backtest", "monitor"],
  "is_default": false,
  "created_at": "2026-03-25",
  "author": "system"
